# Database
DATABASE_URL=postgresql://user:password@localhost:5432/noorvana_loyalty
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Authentication
# IMPORTANT: Use a strong random secret (minimum 64 characters) in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=2h

# API
PORT=3000
NODE_ENV=development
API_VERSION=v1

# Admin Dashboard
ADMIN_FRONTEND_URL=http://localhost:3001

# Client Portal
CLIENT_PORTAL_URL=http://localhost:3002

# AxisCare Integration
# IMPORTANT: Use a strong random secret for webhook signature verification
AXISCARE_WEBHOOK_SECRET=axiscare-webhook-secret-here
AXISCARE_API_BASE_URL=https://api.axiscare.com
AXISCARE_API_KEY=your-axiscare-api-key

# Generic Webhook (Backup)
GENERIC_WEBHOOK_SECRET=generic-webhook-secret-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (SMTP)
# Leave blank to disable email sending (emails will be logged instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NoorVana Advantage <noreply@noorvana.com>

# Boundless Collection fulfillment email
BOUNDLESS_EMAIL=orders@boundlesscollection.com

# Resend Email Service (for password reset emails)
# Sign up at https://resend.com and add your API key
RESEND_API_KEY=
RESEND_FROM_EMAIL=NoorVana Advantage <noreply@noorvana.com>

# Two-Factor Authentication
TOTP_ISSUER=NoorVana Advantage

# Logging
LOG_LEVEL=info
